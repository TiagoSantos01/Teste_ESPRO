        {
          "name": "/aluno",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Cole no Pre-request Script do Postman",
                  "function randomInt(min, max) { return Math.floor(Math.random() * (max - min + 1)) + min; }",
                  "function randomFrom(arr) { return arr[Math.floor(Math.random() * arr.length)]; }",
                  "",
                  "function randomName() {",
                  "  const first = ['João', 'Maria', 'Pedro', 'Ana', 'Carlos', 'Beatriz', 'Lucas', 'Mariana', 'Rafael', 'Gabriela'];",
                  "  const last = ['Silva', 'Souza', 'Oliveira', 'Santos', 'Pereira', 'Costa', 'Almeida', 'Rodrigues'];",
                  "  return `${randomFrom(first)} ${randomFrom(last)}`;",
                  "}",
                  "",
                  "function pad(n, z = 2) { return n.toString().padStart(z, '0'); }",
                  "",
                  "function randomDateISO(startYear = 1970, endYear = 2010) {",
                  "  const y = randomInt(startYear, endYear);",
                  "  const m = pad(randomInt(1, 12));",
                  "  const d = pad(randomInt(1, new Date(y, parseInt(m), 0).getDate()));",
                  "  return `${y}-${m}-${d}`;",
                  "}",
                  "",
                  "// CPF generator (returns 11 digits)",
                  "function generateCPF() {",
                  "  const nums = Array.from({ length: 9 }, () => randomInt(0, 9));",
                  "  const calc = (arr) => {",
                  "    let sum = 0; for (let i = 0; i < arr.length; i++) sum += arr[i] * (arr.length + 1 - i);",
                  "    let r = 11 - (sum % 11); return r >= 10 ? 0 : r;",
                  "  };",
                  "  const d1 = calc(nums);",
                  "  const d2 = calc([...nums, d1]);",
                  "  return nums.join('') + d1.toString() + d2.toString();",
                  "}",
                  "",
                  "function randomEmail(name) {",
                  "  const domain = ['example.com', 'mail.com', 'test.com', 'ex.com'];",
                  "  const local = name.toLowerCase().replace(/\\s+/g, '') + randomInt(1, 999);",
                  "  return `${local}@${randomFrom(domain)}`;",
                  "}",
                  "",
                  "function randomPhone() {",
                  "  const area = pad(randomInt(11, 99));",
                  "  const num = '9' + Array.from({ length: 8 }, () => randomInt(0, 9)).join('');",
                  "  return area + num;",
                  "}",
                  "",
                  "function randomAddress() {",
                  "  const streets = ['Rua das Flores', 'Av. Brasil', 'Rua Rio Branco', 'Rua Afonso Pena', 'Alameda Santos'];",
                  "  return `${randomFrom(streets)}, ${randomInt(1, 9999)}`;",
                  "}",
                  "",
                  "const name = randomName();",
                  "",
                  "pm.collectionVariables.set(\"nome\", name),",
                  "  pm.collectionVariables.set(\"cpf\", generateCPF()),",
                  "  pm.collectionVariables.set(\"data_de_nascimento\", randomDateISO(1970, 2006)),",
                  "  pm.collectionVariables.set(\"email\", randomEmail(name)),",
                  "  pm.collectionVariables.set(\"telefone\", randomPhone()),",
                  "  pm.collectionVariables.set(\"endereco\", randomAddress());",
                  "",
                  "",
                  "const body = {",
                  "  nome: pm.collectionVariables.get(\"nome\"),",
                  "  cpf: pm.collectionVariables.get(\"cpf\"),",
                  "  data_nascimento: pm.collectionVariables.get(\"data_de_nascimento\"),",
                  "  email: pm.collectionVariables.get(\"email\"),",
                  "  telefone: pm.collectionVariables.get(\"telefone\"),",
                  "  endereco: pm.collectionVariables.get(\"endereco\"),",
                  "  cod_turma: Number(pm.collectionVariables.get(\"cod_turma\")),",
                  "};",
                  "pm.request.headers.upsert({ key: 'Content-Type', value: 'application/json' });",
                  "pm.request.body.update(JSON.stringify(body));"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "",
                  "",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"alunoId\", jsonData.id);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
